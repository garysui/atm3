# DuckDB database file (one file: all markets, all layers).
ATM3_DUCKDB_PATH=data/atm3.duckdb

# Root for local data; raw vendor files land under <ATM3_DATA_DIR>/raw/.
ATM3_DATA_DIR=data

# pino log level: trace | debug | info | warn | error
ATM3_LOG_LEVEL=info

# Polygon.io REST key (needed from M2 raw ingestion onward).
POLYGON_API_KEY=
