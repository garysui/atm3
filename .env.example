# Root for all local data: the DuckDB file lands at <ATM3_DATA_DIR>/atm3.duckdb
# and raw vendor files under <ATM3_DATA_DIR>/raw/. On this machine it points at
# the external drive (internal disk is low on space):
ATM3_DATA_DIR=/Volumes/atm-data/atm3/data

# Only set to override the derived <ATM3_DATA_DIR>/atm3.duckdb location.
# ATM3_DUCKDB_PATH=

# pino log level: trace | debug | info | warn | error
ATM3_LOG_LEVEL=info

# API server (npm run serve / npm run dev). It owns the DuckDB WRITE lock
# and runs pipeline operations from the UI; stop it to use CLI scripts or
# npm run status / sql (DuckDB: one writer OR readers, per process).
ATM3_API_HOST=127.0.0.1
ATM3_API_PORT=5180

# Coverage contract (owner 2026-07-09): the daily window starts FIXED at
# 2024-07-01 and grows through yesterday. Keep this pinned — the unset
# default is ROLLING (today - 2y) and would silently shrink coverage.
# verify:continuity asserts no trading day is missing.
ATM3_BACKFILL_FROM=2024-07-01
# ATM3_BACKFILL_TO=  (default: yesterday)

# Intraday minute flat files (~30 MB/day) can use a shorter window than the
# daily backfill; unset means the full shared window above (2 years ≈ 15 GB,
# ~an hour of downloads — widen deliberately).
ATM3_INTRADAY_BACKFILL_FROM=2026-07-06

# Polygon.io REST key (raw ingestion).
POLYGON_API_KEY=

# Polygon/Massive flat files use S3-compatible credentials from the Massive
# dashboard (NOT the REST key), configured as an AWS CLI profile.
ATM3_POLYGON_FLATFILES_AWS_PROFILE=massive-flatfiles

# CN structural prototype. Leave ATM3_CN_SOURCE unset for a US-only setup;
# CN pipeline cards then skip without importing Python or contacting BaoStock.
# ATM3_CN_SOURCE=baostock
ATM3_CN_BACKFILL_FROM=2024-07-01
# ATM3_CN_PYTHON=acquisition/.venv/bin/python3
